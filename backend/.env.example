# Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Postgres
DATABASE_URL=postgresql+psycopg://brawl:brawl@localhost:5432/brawl_draft

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=21600  # 6h

# Supercell API (https://developer.brawlstars.com)
SUPERCELL_API_KEY=
SUPERCELL_API_BASE=https://api.brawlstars.com/v1

# Brawlify scraping
BRAWLIFY_BASE_URL=https://brawlify.com
BRAWLIFY_USER_AGENT=BrawlDraftAssistant/0.1 (+contacto: mauricio.jair)
BRAWLIFY_RATE_LIMIT_SECONDS=1.0

# Claude (Fase 5, opcional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Scoring weights (recalibrables sin redeploy)
W1_WINRATE_MAPA=1.0
W2_COUNTER_SCORE=1.0
W3_SINERGIA=0.8
W4_PICKRATE_RELATIVO=0.5
W5_BAN_RISK=0.6
W6_COUNTERABLE=0.7
W7_PERSONAL_PROFICIENCY=1.2
